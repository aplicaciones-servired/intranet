---
import { SignIn as ClerkSignIn } from "@clerk/astro/components";
import "../styles/global.css";

const { userId } = Astro.locals.auth();
const redirectUrl =
  Astro.url.searchParams.get("redirect_url") ?? "/admin/CartasLaborales";
console.log("first", redirectUrl);

if (userId) {
  return Astro.redirect(redirectUrl);
}

// afterSignInUrl se lee automáticamente desde redirect_url por Clerk
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="../../public/intranet.png" />
  </head>
  <body class="w-full h-full">
    <!-- Overlay de carga -->
    <div
      id="loading-overlay"
      class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-[#f2f4f7]"
    >
      <div class="flex flex-col items-center gap-4 w-64">
        <div
          class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-br from-[#005a9c] to-[#003d6b] text-white"
        >
          <svg
            class="w-8 h-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
            ></path>
          </svg>
        </div>
        <p class="text-gray-600 text-sm font-medium">Verificando sesión...</p>
        <!-- Barra de progreso indeterminada -->
        <div class="w-full h-1.5 bg-gray-200 rounded-full overflow-hidden">
          <div
            id="progress-bar"
            class="h-full bg-gradient-to-r from-[#005a9c] to-[#0078d4] rounded-full"
          >
          </div>
        </div>
      </div>
    </div>

    <div
      class="min-h-screen bg-[#f2f4f7] flex items-center justify-center px-4"
    >
      <div class="max-w-md w-full text-center">
        <div class="flex flex-col items-center gap-6 mt-3">
          <ClerkSignIn
            signUpForceRedirectUrl="/admin"
            forceRedirectUrl="/admin/CartasLaborales"
          />
        </div>
        <div class="flex flex-col sm:flex-row gap-3 justify-center mt-10">
          <a
            href="/"
            class="inline-flex cursor-pointer items-center justify-center gap-2 px-6 py-3 bg-[#005a9c] hover:bg-[#004080] text-white rounded-full font-medium transition-all duration-200 shadow-lg hover:shadow-xl"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              ></path>
            </svg>
            Ir al inicio
          </a>
        </div>
      </div>
    </div>

    <style>
      @keyframes progress-slide {
        0% {
          transform: translateX(-100%);
          width: 40%;
        }
        50% {
          width: 60%;
        }
        100% {
          transform: translateX(260%);
          width: 40%;
        }
      }
      #progress-bar {
        animation: progress-slide 1.4s ease-in-out infinite;
      }
      #loading-overlay {
        transition: opacity 0.3s ease;
      }
      #loading-overlay.hidden {
        opacity: 0;
        pointer-events: none;
      }
    </style>

    <script>
      // Ocultar overlay cuando Clerk termine de montar su componente
      const overlay = document.getElementById("loading-overlay");

      const observer = new MutationObserver(() => {
        // Clerk renderiza un elemento con clase cl-rootBox o cl-card
        const clerkMounted =
          document.querySelector(".cl-rootBox") ||
          document.querySelector(".cl-card") ||
          document.querySelector("[data-clerk-component]");

        if (clerkMounted) {
          overlay?.classList.add("hidden");
          setTimeout(() => overlay?.remove(), 350);
          observer.disconnect();
        }
      });

      observer.observe(document.body, { childList: true, subtree: true });

      // Fallback: ocultar a los 5 segundos si Clerk no responde
      setTimeout(() => {
        overlay?.classList.add("hidden");
        setTimeout(() => overlay?.remove(), 350);
        observer.disconnect();
      }, 5000);
    </script>
  </body>
</html>
